# Virtual Environment
.venv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Data — raw extensions & extracted CRX are too large for GitHub
data/raw/
data/extracted/
data/models/*.pkl
# Forensic reports are generated at runtime (reproduced by re-running forensic)
data/forensic_reports/

# Web uploads (temporary runtime files)
web/uploads/
web/extracted/
web_v2/uploads/
web_v2/extracted/

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store
*.stackdump

# Jupyter checkpoints
.ipynb_checkpoints/

# Output reports (generated at runtime, can be reproduced)
output/

